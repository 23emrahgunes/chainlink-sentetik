# GHOST ORACLE live-mode VPS example
# Copy values into ~/chainlink-sentetik/.env on the VPS. Do not commit real secrets.

TRADING_MODE=LIVE
LIVE_ARMED=0

ORDER_USDC=1
MAX_ORDER_USDC=1
MAX_LIVE_ENTRY_CENTS=20
MAX_DAILY_LOSS_USDC=10
MAX_OPEN_POSITIONS=1

SIGNAL_MAX_STALE_MS=2000
SLIPPAGE_THRESHOLD=0.01
TX_TIMEOUT_SEC=3

DASHBOARD_USER=admin
DASHBOARD_PASS=change-this-password

POLYGON_RPC=https://polygon-rpc.com
WALLET_PRIVATE_KEY=
POLYMARKET_CONTRACT=
POLYMARKET_TOKEN_ID=

POLY_CLOB_API_KEY=
POLY_CLOB_SECRET=
POLY_CLOB_PASSPHRASE=

# Legacy PM_EDGE_* aliases are also accepted. Useful when migrating an older working env:
# PM_EDGE_MOMENTUM_EXECUTION_MODE=dry|live
# PM_EDGE_MOMENTUM_NOTIONAL_USDC=1.00
# PM_EDGE_MOMENTUM_MAX_LIVE_NOTIONAL_USDC=1.00
# PM_EDGE_PRIVATE_KEY=<maps to WALLET_PRIVATE_KEY>
# PM_EDGE_CLOB_API_KEY=<maps to POLY_API_KEY>
# PM_EDGE_CLOB_API_SECRET=<maps to POLY_API_SECRET>
# PM_EDGE_CLOB_API_PASSPHRASE=<maps to POLY_API_PASSPHRASE>
# PM_EDGE_CLOB_HOST=https://clob.polymarket.com
# PM_EDGE_CHAIN_ID=137
# PM_EDGE_CLOB_HTTP_TIMEOUT_SECONDS=15
# PM_EDGE_SIGNATURE_TYPE=3
